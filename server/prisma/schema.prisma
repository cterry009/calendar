generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum DevicePlatform {
  WEB
  ANDROID
  IOS
  WINDOWS
  MACOS
}

enum TaskDifficulty {
  EASY
  MEDIUM
  HARD
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ScheduleKind {
  WORK
  REST
}

enum PomodoroState {
  IDLE
  FOCUS
  SHORT_BREAK
  LONG_BREAK
}

enum BlockListKind {
  MOBILE_APP
  WEBSITE
  DESKTOP_APP
}

enum FitnessIntensity {
  LOW
  MEDIUM
  HIGH
}

enum FitnessSource {
  MANUAL
  HEALTH_CONNECT
  HEALTHKIT
  CSV_IMPORT
}

enum AnalyticsPeriod {
  DAILY
  WEEKLY
  MONTHLY
}

// ─── Auth & devices ──────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  name         String?
  googleId     String?  @unique
  appleId      String?  @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  devices            Device[]
  tasks              Task[]
  schedules          Schedule[]
  pomodoroSessions   PomodoroSession[]
  blockListEntries   BlockListEntry[]
  fitnessEntries     FitnessEntry[]
  analyticsSnapshots AnalyticsSnapshot[]
  detoxPlan          DetoxPlan?

  @@map("users")
}

model Device {
  id           String         @id @default(cuid())
  userId       String
  label        String
  platform     DevicePlatform
  refreshToken String?        @unique
  lastSeenAt   DateTime       @default(now())
  revokedAt    DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("devices")
}

// ─── Calendar & tasks ────────────────────────────────────────────────────────

model Task {
  id               String         @id @default(cuid())
  userId           String
  title            String
  description      String?
  scheduledAt      DateTime?
  estimatedMinutes Int
  actualMinutes    Int?
  difficulty       TaskDifficulty @default(MEDIUM)
  complexity       Int            @default(5) // 1–10
  priority         TaskPriority   @default(MEDIUM)
  category         String?
  status           TaskStatus     @default(PENDING)
  completedAt      DateTime?
  clientId         String? // offline sync id from client
  deletedAt        DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  pomodoroSessions PomodoroSession[]

  @@unique([userId, clientId])
  @@index([userId, scheduledAt])
  @@index([userId, status])
  @@map("tasks")
}

model Schedule {
  id          String       @id @default(cuid())
  userId      String
  kind        ScheduleKind
  dayOfWeek   Int // 0 = Sunday … 6 = Saturday
  startMinute Int // minutes from midnight (0–1439)
  endMinute   Int
  label       String?
  enabled     Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, kind])
  @@map("schedules")
}

// ─── Pomodoro ────────────────────────────────────────────────────────────────

model PomodoroSession {
  id                    String        @id @default(cuid())
  userId                String
  taskId                String?
  state                 PomodoroState @default(IDLE)
  focusDurationMin      Int           @default(25)
  shortBreakMin         Int           @default(5)
  longBreakMin          Int           @default(15)
  cyclesBeforeLongBreak Int           @default(4)
  completedCycles       Int           @default(0)
  active                Boolean       @default(false)
  interrupted           Boolean       @default(false)
  startedAt             DateTime?
  endedAt               DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  task Task? @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([userId, active])
  @@map("pomodoro_sessions")
}

// ─── Focus blocking ──────────────────────────────────────────────────────────

model BlockListEntry {
  id           String         @id @default(cuid())
  userId       String
  kind         BlockListKind
  identifier   String // package name, domain, or exe name
  label        String
  platform     DevicePlatform?
  highDopamine Boolean        @default(false) // serotonin / detox mode
  enabled      Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, kind, identifier])
  @@index([userId])
  @@map("block_list_entries")
}

// ─── Fitness ─────────────────────────────────────────────────────────────────

model FitnessEntry {
  id              String           @id @default(cuid())
  userId          String
  activityType    String
  durationMinutes Int
  intensity       FitnessIntensity @default(MEDIUM)
  notes           String?
  loggedAt        DateTime
  source          FitnessSource    @default(MANUAL)
  externalId      String? // HealthKit / Health Connect id
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, loggedAt])
  @@map("fitness_entries")
}

// ─── Serotonin detox plan ────────────────────────────────────────────────────

model DetoxPlan {
  id        String   @id @default(cuid())
  userId    String   @unique
  planData  Json
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("detox_plans")
}

// ─── Analytics ───────────────────────────────────────────────────────────────

model AnalyticsSnapshot {
  id                    String          @id @default(cuid())
  userId                String
  period                AnalyticsPeriod
  periodStart           DateTime
  periodEnd             DateTime
  tasksCompleted        Int             @default(0)
  pomodorosCompleted    Int             @default(0)
  pomodorosInterrupted  Int             @default(0)
  focusMinutes          Int             @default(0)
  estimatedMinutes      Int             @default(0)
  actualMinutes         Int             @default(0)
  estimationErrorPct    Float?
  serotoninScore        Int?
  fitnessMinutes        Int             @default(0)
  suggestions           Json? // rule-based suggestions generated for the period
  metadata              Json? // extra breakdown (by difficulty, peak hours, etc.)
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, period, periodStart])
  @@index([userId, periodStart])
  @@map("analytics_snapshots")
}
